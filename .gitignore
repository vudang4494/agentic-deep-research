# ============================================================
# Outputs (per-run artifacts -- regenerated by the pipeline)
# ============================================================
files/output/*
!files/output/.gitkeep
!files/output/benchmark.md

# Research cache (URL fetches -- regenerated on demand)
files/research/cache/*
!files/research/cache/.gitkeep

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs
.venv/
venv/
env/

# ============================================================
# Secrets / env
# ============================================================
.env
.env.local
.env.*.local
*.pem
*.key

# ============================================================
# macOS / IDE
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
.idea/
.vscode/
*.swp
*.swo

# ============================================================
# Other-tool configs (project is Claude-native)
# ============================================================
.cursor/
.cursor-plugin/
.codex-plugin/
**/.cursor-plugin/

# ============================================================
# Logs
# ============================================================
*.log
nohup.out

# ============================================================
# Misc temp
# ============================================================
/tmp_*
.cache/

# Local GGUF model weights (multi-GB, not committed)
models/
